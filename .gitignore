# Secrets — never commit
.env

# Per-app secrets, consumed via each service's env_file (see compose.yaml).
# Ship only the *.env.example templates.
duri.env

# cloudflared tunnel credentials (created by `cloudflared tunnel create`,
# named <tunnel-id>.json). Scoped on purpose — do NOT blanket-ignore *.json;
# a config/compose tool may legitimately want a tracked JSON later.
cloudflared/*.json

# OS cruft
.DS_Store
