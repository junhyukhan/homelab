# Copy to duri.env (gitignored) and fill in. Consumed by the `duri` service via
# env_file in compose.yaml. These are duri's SERVER-ONLY application secrets and
# are scoped to the app — they do NOT belong in the shared .env.
#
# NOTE: the client-side NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
# are baked into the image at BUILD time (on the dev machine), not set here.
# Values come from the duri repo's own prod env (its .env.hosted). Keep the
# service-role key, DB password, and Anthropic key OUT of git.

# Supabase (Seoul) — server-only admin key. Bypasses RLS; treat as admin.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle (Supabase pooler, direct or :6543).
DATABASE_URL=

# Anthropic API key for the broker-import LLM mapping. Server-only.
ANTHROPIC_API_KEY=
