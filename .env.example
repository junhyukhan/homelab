# Copy to .env (gitignored) and fill in. See SPEC.md §Constraints for what
# consumes each key. The cloudflared tunnel does NOT use an env var — its
# credentials are a gitignored JSON file (see docs/tunnel-setup.md).

# Timezone for Home Assistant (and future services).
TZ=Asia/Seoul

# The box's stable Tailscale IP. Used to bind published ports to the tailnet
# interface only (never 0.0.0.0), keeping services off the home LAN.
TAILSCALE_IP=100.65.77.63

# Canonical registry address: ${TAILSCALE_IP}:30500. Own-service image refs use
# ${REGISTRY_HOST}/<name>:<tag>. Keep it in sync with TAILSCALE_IP (.env can't
# reference another var). The box's own /etc/docker/daemon.json also needs this
# value as a literal in insecure-registries (daemon.json can't read env).
REGISTRY_HOST=100.65.77.63:30500

# Base domain for public (Cloudflare) routes. Reserved: unused until a
# cloudflared ingress route exists. Set to your domain when that day comes.
BASE_DOMAIN=example.com

# Reserved / forward-looking. Not consumed by the current services (registry:2
# and the Home Assistant image run as root). Kept for future services that
# honor PUID/PGID (e.g. linuxserver-style images).
PUID=1000
PGID=1000
